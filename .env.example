# Copy to .env in repo root (optional — backend loads backend/.env)

# PostgreSQL (must match docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://headhunter:headhunter@127.0.0.1:5432/headhunter
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://headhunter:headhunter@127.0.0.1:5432/headhunter

# Optional; backend defaults are dev-only — set in production
JWT_SECRET=change-me

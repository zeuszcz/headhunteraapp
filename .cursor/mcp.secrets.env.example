# Copy this file to .cursor/mcp.secrets.env (already ignored in git)
# and fill values to connect MCP servers to provider/server data.

# 21st.dev Magic MCP
API_KEY=your_21st_dev_api_key
# Optional alias if you prefer a separate name:
# MAGIC_API_KEY=your_21st_dev_api_key

# Ruflo / provider keys (optional, depending on enabled tool groups)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

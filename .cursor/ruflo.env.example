# Пример переменных для Ruflo MCP (НЕ коммитить файлы с реальными ключами).
# Способ 1: переменные окружения Windows / Linux (User или System).
# Способ 2: Cursor → Settings → MCP → ruflo → добавить те же ключи в Environment.
#
# Для вызовов моделей через Anthropic (часто обязательно):
# ANTHROPIC_API_KEY=sk-ant-...
#
# Опционально:
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
